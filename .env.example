# Токен бота от @BotFather
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Ваш Telegram user id (напишите боту любое сообщение — он подскажет id, пока ADMIN_CHAT_ID не заполнен)
ADMIN_CHAT_ID=000000000

# Публичный HTTPS-адрес сервера (для Web App обязателен HTTPS, напр. https://project.uz или адрес от ngrok)
BASE_URL=http://localhost:3000

PORT=3000

# 1 = разрешить открывать форму в обычном браузере без Telegram (ТОЛЬКО для локальной разработки)
# DEV_NO_AUTH=1

# Ключ Яндекс.Карт (developer.tech.yandex.ru) — без него карта работает в dev-режиме
YANDEX_MAPS_API_KEY=

# Извлечение аудио из видео (Instagram/TikTok/YouTube): cobalt-совместимый API
# (self-hosted github.com/imputnet/cobalt или платный инстанс). Без настройки кнопка недоступна.
EXTRACT_API_URL=
EXTRACT_API_KEY=
